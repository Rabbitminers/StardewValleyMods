<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <Authors>Rabbitminers</Authors>
        <RootNamespace>Rabbitminers.Stardew.WheresMyStuff</RootNamespace>

        <TargetFramework>net6.0</TargetFramework>

        <ImplicitUsings>enable</ImplicitUsings>
        <LangVersion>latest</LangVersion>
        <Nullable>enable</Nullable>
        
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <ModZipPath>$(MSBuildThisFileDirectory)/_releases</ModZipPath>
    </PropertyGroup>

    <ItemGroup>
        <Reference Include="StardewModdingAPI">
            <HintPath>..\..\..\..\..\Program Files (x86)\Steam\steamapps\common\Stardew Valley\StardewModdingAPI.dll</HintPath>
        </Reference>
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="Pathoschild.Stardew.ModBuildConfig" Version="4.4.0" />
    </ItemGroup>

    <ItemGroup>
      <Folder Include="Assets\" />
    </ItemGroup>
</Project>
